# PKI bootstrap working directory (generated by scripts/bootstrap-pki.sh)
.pki/
# Allow the CA cert placeholder in the workstation role (replaced at bootstrap time)
# The actual cert content is safe to commit (it is a public CA certificate, not a private key)
!ansible/roles/workstation/files/demo-corp-root-ca.crt
